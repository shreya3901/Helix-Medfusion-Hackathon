<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CogniSurv — Team Helix · MedFusion 2026</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Syne:wght@400;600;700&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#060B18;--surface:#0D1526;--surface2:#132038;--surface3:#1A2A47;
  --border:#1E3A5F;--border2:#2A4F7A;--text:#E8F0FC;--muted:#6B8CAE;
  --accent:#F472B6;--accent2:#FB923C;--red:#F87171;--amber:#FBBF24;
  --green:#34D399;--blue:#38BDF8;--purple:#818CF8;
  --font:'Syne',sans-serif;--mono:'JetBrains Mono',monospace;
}
html,body{height:100%;overflow:hidden}
body{background:var(--bg);color:var(--text);font-family:var(--font);display:flex;flex-direction:column}

/* ── HEADER ── */
.header{padding:10px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--surface);flex-shrink:0;gap:12px}
.hleft{display:flex;align-items:center;gap:10px;flex-shrink:0}
.helix-icon{width:30px;height:30px;border-radius:8px;background:linear-gradient(135deg,#F472B6,#FB923C);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#fff;flex-shrink:0}
.helix-name{font-size:16px;font-weight:700;background:linear-gradient(135deg,#F472B6,#FB923C);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.vdiv{width:1px;height:26px;background:var(--border)}
.htitle{font-size:13px;font-weight:600}
.hsub{font-size:10px;color:var(--muted);font-family:var(--mono)}
.event-badge{font-size:9px;padding:3px 9px;border-radius:20px;background:rgba(244,114,182,.1);border:1px solid rgba(244,114,182,.25);color:#FBCFE8;font-family:var(--mono);white-space:nowrap}
.live-dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:pulse 2s infinite;flex-shrink:0}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(52,211,153,.5)}50%{box-shadow:0 0 0 5px rgba(52,211,153,0)}}
.hstats{display:flex;align-items:center;gap:0;flex-shrink:0}
.hstat{text-align:center;padding:0 12px;border-left:1px solid var(--border)}
.hstat-val{font-size:15px;font-weight:700;font-family:var(--mono)}
.hstat-lbl{font-size:9px;color:var(--muted)}

/* ── GLOBAL QUERY BAR ── */
.query-bar{padding:8px 18px;background:var(--surface2);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;flex-shrink:0}
.query-label{font-size:10px;color:var(--muted);font-family:var(--mono);white-space:nowrap;flex-shrink:0}
.qinput-wrap{flex:1;position:relative;max-width:500px}
.qinput{width:100%;background:var(--surface);border:1px solid var(--border2);border-radius:8px;padding:7px 12px 7px 32px;color:var(--text);font-family:var(--font);font-size:12px;outline:none;transition:border .2s}
.qinput:focus{border-color:var(--accent)}
.qinput::placeholder{color:var(--muted)}
.qinput-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);font-size:13px;pointer-events:none}
.qsuggestions{position:absolute;top:calc(100% + 4px);left:0;right:0;background:var(--surface);border:1px solid var(--border2);border-radius:8px;z-index:3000;overflow:hidden;display:none;box-shadow:0 8px 30px rgba(0,0,0,.5)}
.qsugg-item{padding:9px 12px;cursor:pointer;font-size:11px;display:flex;align-items:center;gap:8px;border-bottom:1px solid var(--border)}
.qsugg-item:last-child{border-bottom:none}
.qsugg-item:hover{background:var(--surface2)}
.qsugg-type{font-size:9px;font-family:var(--mono);padding:2px 6px;border-radius:6px}
.qchips{display:flex;gap:6px;flex-wrap:wrap}
.qchip{font-size:10px;padding:4px 10px;border-radius:20px;cursor:pointer;font-family:var(--mono);border:1px solid var(--border);color:var(--muted);transition:all .15s;white-space:nowrap}
.qchip:hover,.qchip.active{background:rgba(244,114,182,.15);border-color:rgba(244,114,182,.4);color:#FBCFE8}

/* ── NAV ── */
.nav{display:flex;background:var(--surface);border-bottom:1px solid var(--border);flex-shrink:0;padding:0 18px;gap:2px;overflow-x:auto}
.nav::-webkit-scrollbar{height:0}
.ntab{padding:8px 14px;font-size:10px;font-weight:600;letter-spacing:.7px;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;white-space:nowrap;text-transform:uppercase}
.ntab:hover{color:var(--text)}
.ntab.active{color:var(--accent);border-bottom-color:var(--accent)}

/* ── MAIN ── */
.main{display:flex;flex:1;overflow:hidden}
.panel{display:none;flex:1;overflow:hidden}
.panel.active{display:flex}

/* ── SIDEBAR ── */
.sidebar{width:248px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;overflow:hidden}
.sb-sec{padding:11px 13px;border-bottom:1px solid var(--border)}
.sblabel{font-size:9px;font-weight:600;letter-spacing:1.8px;text-transform:uppercase;color:var(--muted);margin-bottom:7px;font-family:var(--mono)}
.rfpills{display:flex;gap:5px}
.rfpill{font-size:9px;padding:4px 10px;border-radius:20px;cursor:pointer;font-family:var(--mono);transition:all .15s;border:1px solid var(--border);color:var(--muted)}
.rfpill.a-all{background:rgba(248,113,113,.15);border-color:rgba(248,113,113,.4);color:#FCA5A5}
.rfpill.a-mat{background:rgba(244,114,182,.15);border-color:rgba(244,114,182,.4);color:#FBCFE8}
.rfpill.a-ane{background:rgba(251,191,36,.15);border-color:rgba(251,191,36,.4);color:#FDE68A}
.sinput{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:6px 10px;color:var(--text);font-family:var(--mono);font-size:11px;outline:none;transition:border .2s}
.sinput:focus{border-color:var(--accent)}
.sinput::placeholder{color:var(--muted)}
.cnt-badge{font-size:10px;color:var(--muted);font-family:var(--mono);padding:5px 13px 2px}
.dlist{flex:1;overflow-y:auto;padding:5px}
.dlist::-webkit-scrollbar{width:2px}
.dlist::-webkit-scrollbar-thumb{background:var(--border2)}
.ditem{padding:8px 10px;border-radius:7px;cursor:pointer;transition:background .12s;margin-bottom:3px;border:1px solid transparent}
.ditem:hover{background:var(--surface2)}
.ditem.active{background:var(--surface3);border-color:var(--border2)}
.dname{font-size:11px;font-weight:700}
.dmeta{font-size:10px;color:var(--muted);font-family:var(--mono);margin-top:1px}
.rbar-wrap{margin-top:4px;height:2px;background:var(--border);border-radius:1px}
.rbar{height:2px;border-radius:1px}
.dtype-dot{width:5px;height:5px;border-radius:50%;display:inline-block;margin-right:3px;vertical-align:middle}

/* ── MAP ── */
#map{flex:1}
.leaflet-container{background:#060B18!important}
.leaflet-tile-pane{filter:brightness(0.35) saturate(0.2) hue-rotate(210deg)}
.leaflet-control-attribution{display:none}
.leaflet-control-zoom a{background:var(--surface)!important;color:var(--text)!important;border-color:var(--border)!important}
.map-legend{position:absolute;bottom:14px;left:262px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:9px 11px;z-index:1000;pointer-events:none}
.legttl{font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:7px;font-family:var(--mono)}
.legrow{display:flex;align-items:center;gap:7px;font-size:10px;color:var(--muted);margin-bottom:4px}

/* ── AI PANEL ── */
.ai-panel{width:326px;background:var(--surface);border-left:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0}
.ap-hdr{padding:11px 13px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.ap-icon{width:22px;height:22px;border-radius:5px;background:linear-gradient(135deg,rgba(244,114,182,.3),rgba(251,146,60,.3));border:1px solid rgba(244,114,182,.4);display:flex;align-items:center;justify-content:center;font-size:11px}
.ap-body{flex:1;overflow-y:auto;padding:13px}
.ap-body::-webkit-scrollbar{width:2px}
.ap-body::-webkit-scrollbar-thumb{background:var(--border2)}
.empty-s{height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--muted);text-align:center;gap:10px;padding:20px}

/* Detail content */
.dname-big{font-size:14px;font-weight:700;margin-bottom:2px}
.dstate-line{font-size:10px;color:var(--muted);font-family:var(--mono);margin-bottom:10px}

/* Rate of change badge */
.roc-badge{display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:8px;margin-bottom:10px;border:1px solid}
.roc-up{background:rgba(248,113,113,.08);border-color:rgba(248,113,113,.25)}
.roc-stable{background:rgba(251,191,36,.08);border-color:rgba(251,191,36,.25)}
.roc-down{background:rgba(52,211,153,.08);border-color:rgba(52,211,153,.25)}
.roc-label{font-size:10px;flex:1;line-height:1.4}
.roc-val{font-size:12px;font-weight:700;font-family:var(--mono)}

/* Plain english box */
.plain-box{background:var(--surface3);border-radius:8px;padding:9px 11px;margin-bottom:10px;border-left:3px solid var(--accent)}
.plain-box-lbl{font-size:9px;letter-spacing:1.2px;text-transform:uppercase;color:var(--accent);font-family:var(--mono);margin-bottom:4px}
.plain-box-text{font-size:11px;line-height:1.6;color:#C8D8F0}

.gauge-card{background:var(--surface2);border-radius:8px;padding:11px;margin-bottom:10px;border:1px solid var(--border);display:flex;align-items:center;gap:11px}
.gauge-wrap{width:50px;height:50px;position:relative;flex-shrink:0}
.gauge-wrap svg{transform:rotate(-90deg)}
.gauge-num{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;font-family:var(--mono)}
.sec-label{font-size:9px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);font-family:var(--mono);margin:10px 0 6px}
.driver-row{display:flex;align-items:center;gap:6px;margin-bottom:6px}
.dicon{width:5px;height:5px;border-radius:50%;flex-shrink:0}
.dtext{font-size:11px;flex:1;line-height:1.3}
.dval{font-size:10px;font-family:var(--mono);color:var(--muted);flex-shrink:0}
.dbar-w{width:44px;height:2px;background:var(--border);border-radius:1px;flex-shrink:0}
.dbar{height:2px;border-radius:1px}
.spark-card{background:var(--surface2);border-radius:8px;padding:9px 11px;border:1px solid var(--border)}
.ai-card{background:var(--surface2);border-radius:8px;padding:11px;border:1px solid var(--border);margin-top:10px}
.ai-label{font-size:9px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);font-family:var(--mono);margin-bottom:7px;display:flex;align-items:center;gap:5px}
.ai-text{font-size:11px;line-height:1.8;color:#B8CCEC}
.tcursor{display:inline-block;width:2px;height:11px;background:var(--accent);animation:blink .7s infinite;vertical-align:middle;margin-left:1px}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}

/* ── SCROLLABLE PANELS ── */
.scroll-panel{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:13px}
.scroll-panel::-webkit-scrollbar{width:3px}
.scroll-panel::-webkit-scrollbar-thumb{background:var(--border2)}
.card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:13px}
.card-title{font-size:11px;font-weight:700;margin-bottom:11px;display:flex;align-items:center;gap:7px;flex-wrap:wrap}
.ctag{font-size:9px;padding:2px 7px;border-radius:10px;font-family:var(--mono)}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:11px}
.grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.stat-box{background:var(--surface2);border-radius:8px;padding:11px;border:1px solid var(--border)}
.stat-val{font-size:20px;font-weight:700;font-family:var(--mono);margin-bottom:2px}
.stat-lbl{font-size:10px;color:var(--muted);line-height:1.4}
.stat-delta{font-size:10px;font-family:var(--mono);margin-top:3px}
.ch{position:relative;height:200px}
.ch-sm{position:relative;height:160px}
.ch-lg{position:relative;height:240px}

/* Outbreak timeline */
.timeline{position:relative;padding:8px 0 0 16px}
.tl-line{position:absolute;left:16px;top:0;bottom:0;width:1px;background:linear-gradient(180deg,rgba(244,114,182,.5),rgba(30,58,95,.2))}
.tl-item{position:relative;padding:0 0 16px 24px;cursor:pointer}
.tl-dot{position:absolute;left:-4px;top:3px;width:9px;height:9px;border-radius:50%;border:1.5px solid var(--surface);flex-shrink:0}
.tl-header{display:flex;align-items:center;gap:7px;margin-bottom:3px;flex-wrap:wrap}
.tl-date{font-size:9px;font-family:var(--mono);color:var(--muted)}
.tl-src{font-size:9px;padding:1px 6px;border-radius:8px;font-family:var(--mono)}
.tl-title{font-size:11px;font-weight:600;margin-bottom:2px}
.tl-desc{font-size:10px;color:var(--muted);line-height:1.5}
.tl-item:hover .tl-title{color:var(--accent)}

/* Alert feed */
.alert-row{display:flex;align-items:flex-start;gap:9px;padding:8px 0;border-bottom:1px solid var(--border)}
.alert-row:last-child{border-bottom:none}
.alert-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:3px}
.alert-src{font-size:9px;font-family:var(--mono);color:var(--muted);margin-bottom:2px}
.alert-text{font-size:11px;line-height:1.5}
.alert-time{font-size:9px;color:var(--muted);font-family:var(--mono);margin-top:2px}

/* Source tags */
.stag{display:inline-flex;align-items:center;font-size:9px;padding:2px 7px;border-radius:10px;font-family:var(--mono);margin:2px 2px 0 0}
.stag.who{background:rgba(56,189,248,.1);border:1px solid rgba(56,189,248,.25);color:#7DD3FC}
.stag.promed{background:rgba(251,191,36,.1);border:1px solid rgba(251,191,36,.25);color:#FDE68A}
.stag.nfhs{background:rgba(244,114,182,.1);border:1px solid rgba(244,114,182,.25);color:#FBCFE8}
.stag.cdc{background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.25);color:#6EE7B7}
.stag.hmap{background:rgba(129,140,248,.1);border:1px solid rgba(129,140,248,.25);color:#C4B5FD}
.stag.ecdc{background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.25);color:#FCA5A5}
.stag.dis{background:rgba(56,189,248,.1);border:1px solid rgba(56,189,248,.25);color:#7DD3FC}

/* Data table */
.dtable{width:100%;border-collapse:collapse;font-size:11px}
.dtable th{font-size:9px;font-family:var(--mono);color:var(--muted);letter-spacing:1px;text-transform:uppercase;padding:6px 8px;border-bottom:1px solid var(--border);text-align:left;background:var(--surface2)}
.dtable td{padding:6px 8px;border-bottom:1px solid var(--border)}
.dtable tr:hover td{background:rgba(19,32,56,.5)}

/* Query results panel */
.qresult{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:13px}
.qresult::-webkit-scrollbar{width:3px}
.qresult::-webkit-scrollbar-thumb{background:var(--border2)}
.qr-hero{background:linear-gradient(135deg,rgba(244,114,182,.08),rgba(251,146,60,.05));border:1px solid rgba(244,114,182,.2);border-radius:10px;padding:14px 16px}
.qr-title{font-size:16px;font-weight:700;margin-bottom:4px}
.qr-sub{font-size:11px;color:var(--muted);line-height:1.6}

.spinner{width:20px;height:20px;border:2px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

/* Tooltip */
.leaflet-tooltip{background:var(--surface)!important;border:1px solid var(--border)!important;border-radius:7px!important;color:var(--text)!important;font-family:var(--font)!important;font-size:11px!important;padding:7px 11px!important;box-shadow:0 4px 20px rgba(0,0,0,.6)!important}
.leaflet-tooltip-top::before{border-top-color:var(--border)!important}
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="hleft">
    <div class="helix-icon">⌬</div>
    <div class="helix-name">Helix</div>
    <div class="vdiv"></div>
    <div>
      <div class="htitle">CogniSurv — Maternal &amp; Anemia Surveillance</div>
      <div class="hsub">Cognitive Disease Surveillance Map · India · AI-Powered Risk Intelligence</div>
    </div>
    <div class="event-badge">MedFusion Hackfest 2026</div>
  </div>
  <div class="hstats">
    <div style="display:flex;align-items:center;gap:5px;padding:0 12px;border-left:1px solid var(--border)">
      <div class="live-dot"></div>
      <span style="font-size:10px;color:var(--muted);font-family:var(--mono)">Live</span>
    </div>
    <div class="hstat"><div class="hstat-val" style="color:#F87171" id="h-crit">—</div><div class="hstat-lbl">Critical Districts</div></div>
    <div class="hstat"><div class="hstat-val" style="color:#FBBF24">97</div><div class="hstat-lbl">India MMR/100K</div></div>
    <div class="hstat"><div class="hstat-val" style="color:#F472B6">57%</div><div class="hstat-lbl">Anemia in Women</div></div>
  </div>
</div>

<!-- GLOBAL QUERY BAR -->
<div class="query-bar">
  <div class="query-label">🔍 QUERY:</div>
  <div class="qinput-wrap">
    <span class="qinput-icon">⌕</span>
    <input class="qinput" id="gquery" type="text" placeholder="Search any disease, region, or indicator — e.g. 'Bihar anemia' or 'maternal mortality UP'…" oninput="handleQuery(this.value)" onfocus="showSuggestions()" onblur="setTimeout(hideSuggestions,200)">
    <div class="qsuggestions" id="qsugg"></div>
  </div>
  <div class="qchips">
    <div class="qchip" onclick="runQuery('Maternal Mortality Bihar')">Maternal · Bihar</div>
    <div class="qchip" onclick="runQuery('Anemia UP')">Anemia · UP</div>
    <div class="qchip" onclick="runQuery('Critical districts')">Critical Districts</div>
    <div class="qchip" onclick="runQuery('Kerala benchmark')">Kerala Benchmark</div>
    <div class="qchip" onclick="runQuery('Escalating risk')">Escalating Risk</div>
  </div>
</div>

<!-- NAV TABS -->
<div class="nav">
  <div class="ntab active" onclick="switchTab('map')" id="tab-map">🗺 Risk Map</div>
  <div class="ntab" onclick="switchTab('query')" id="tab-query">🔍 Query Results</div>
  <div class="ntab" onclick="switchTab('surv')" id="tab-surv">📊 Surveillance Data</div>
  <div class="ntab" onclick="switchTab('timeline')" id="tab-timeline">📅 Outbreak Timeline</div>
  <div class="ntab" onclick="switchTab('trends')" id="tab-trends">📈 Historical Trends</div>
</div>

<!-- MAIN -->
<div class="main">

  <!-- ══ MAP ══ -->
  <div class="panel active" id="panel-map">
    <div class="sidebar">
      <div class="sb-sec">
        <div class="sblabel">Focus Layer</div>
        <div class="rfpills">
          <div class="rfpill a-all" id="rf-all" onclick="setFilter('all')">All</div>
          <div class="rfpill" id="rf-mat" onclick="setFilter('mat')">Maternal</div>
          <div class="rfpill" id="rf-ane" onclick="setFilter('ane')">Anemia</div>
        </div>
      </div>
      <div class="sb-sec" style="padding:9px 12px">
        <input class="sinput" id="search" type="text" placeholder="Search district / state…" oninput="renderList()">
      </div>
      <div class="cnt-badge" id="cnt-badge"></div>
      <div class="dlist" id="dlist"></div>
    </div>

    <div style="flex:1;position:relative;overflow:hidden">
      <div id="map" style="width:100%;height:100%"></div>
      <div class="map-legend">
        <div class="legttl">Risk Score</div>
        <div class="legrow"><div style="width:7px;height:7px;border-radius:50%;background:#F87171"></div>Critical 80–100</div>
        <div class="legrow"><div style="width:7px;height:7px;border-radius:50%;background:#FB923C"></div>High 60–79</div>
        <div class="legrow"><div style="width:7px;height:7px;border-radius:50%;background:#FBBF24"></div>Moderate 40–59</div>
        <div class="legrow"><div style="width:7px;height:7px;border-radius:50%;background:#34D399"></div>Low 0–39</div>
        <div style="margin:6px 0 4px;font-size:9px;color:var(--muted);font-family:var(--mono)">── Primary Focus</div>
        <div class="legrow"><div class="dtype-dot" style="background:#F472B6"></div>Maternal</div>
        <div class="legrow"><div class="dtype-dot" style="background:#FBBF24"></div>Anemia</div>
      </div>
    </div>

    <div class="ai-panel">
      <div class="ap-hdr">
