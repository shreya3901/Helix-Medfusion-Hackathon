function handleQuery(v){
  if(!v){hideSuggestions();return;}
  const matches=queryIndex.filter(x=>x.label.toLowerCase().includes(v.toLowerCase())).slice(0,6);
  if(!matches.length){hideSuggestions();return;}
  const el=document.getElementById('qsugg');
  el.style.display='block';
  el.innerHTML=matches.map(m=>`
    <div class="qsugg-item" onclick="runQueryItem('${m.label}','${m.type}','${m.id||m.filter||''}')">
      <span class="qsugg-type" style="background:rgba(244,114,182,.1);border:1px solid rgba(244,114,182,.25);color:#FBCFE8">${m.type}</span>
      <span style="flex:1">${m.label}</span>
      <span style="font-size:9px;color:var(--muted);font-family:var(--mono)">${m.hint}</span>
    </div>`).join('');
}
function showSuggestions(){handleQuery(document.getElementById('gquery').value)}
function hideSuggestions(){document.getElementById('qsugg').style.display='none'}
function runQueryItem(label,type,id){
  document.getElementById('gquery').value=label;
  hideSuggestions();
  if(type==='district'){runQueryDistrict(id);}
  else{runQuery(label);}
}
function runQuery(q){
  document.getElementById('gquery').value=q;
  hideSuggestions();
  switchTab('query');
  const ql=q.toLowerCase();
  let results=[];
  if(ql.includes('critical')||ql.includes('urgent')) results=districts.filter(d=>d.risk>=80);
  else if(ql.includes('escalat')) results=districts.filter(d=>d.roc>=6);
  else if(ql.includes('kerala')||ql.includes('benchmark')) results=districts.filter(d=>d.risk<30);
  else if(ql.includes('anemia')||ql.includes('ane')) results=districts.filter(d=>d.type==='ane');
  else if(ql.includes('maternal')||ql.includes('mat')) results=districts.filter(d=>d.type==='mat');
  else{
    results=districts.filter(d=>d.name.toLowerCase().includes(ql)||d.state.toLowerCase().includes(ql));
    if(!results.length) results=districts.filter(d=>d.type==='mat'||d.type==='ane').sort((a,b)=>b.risk-a.risk).slice(0,8);
  }
  results=results.sort((a,b)=>b.risk-a.risk);
  const el=document.getElementById('qresult-body');
  const topDistrict=results[0];
  el.innerHTML=`
    <div class="qr-hero">
      <div class="qr-title">Results for: "${q}"</div>
      <div class="qr-sub">${results.length} district${results.length!==1?'s':''} matched · sorted by risk score · Sources: NFHS-5, WHO GHO, RF Risk Model</div>
    </div>
    ${topDistrict?`
    <div class="card">
      <div class="card-title">⚡ Highest Risk Match
        <span class="stag nfhs">NFHS-5</span><span class="stag who">WHO GHO</span>
      </div>
