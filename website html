          <div style="font-size:18px;font-weight:700;margin-bottom:4px">${topDistrict.name}, ${topDistrict.state}</div>
          <div style="font-size:11px;color:var(--muted);margin-bottom:8px">${getTypeInfo(topDistrict.type).label} · Risk Score: <span style="color:${getRiskColor(topDistrict.risk)};font-weight:700">${topDistrict.risk}</span> · ${getRiskCat(topDistrict.risk).label}</div>
          <div class="plain-box" style="margin-bottom:0"><div class="plain-box-lbl">💡 Plain English</div><div class="plain-box-text">${getPlainEnglish(topDistrict)}</div></div>
        </div>
      </div>
    </div>`:''}
    <div class="card">
      <div class="card-title">All Matching Districts
        <span class="stag nfhs">NFHS-5</span>
      </div>
      <table class="dtable">
        <thead><tr><th>District</th><th>State</th><th>Focus</th><th>Risk Score</th><th>Rate of Change</th><th>Top Driver</th></tr></thead>
        <tbody>${results.map(d=>{
          const ti=getTypeInfo(d.type), ri=getRoCInfo(d.roc);
          return`<tr style="cursor:pointer" onclick="switchTab('map');setTimeout(()=>selectDistrict('${d.id}'),100)">
            <td style="font-weight:700">${d.name}</td>
            <td>${d.state}</td>
            <td><span style="color:${ti.color};font-family:var(--mono);font-size:10px">${ti.label}</span></td>
            <td><span style="font-family:var(--mono);font-weight:700;color:${getRiskColor(d.risk)}">${d.risk}</span></td>
            <td><span style="font-family:var(--mono);font-size:10px;color:${ri.color}">${ri.icon} ${d.roc>0?'+':''}${d.roc}/mo</span></td>
            <td style="font-size:10px;color:var(--muted)">${d.drivers[0].name} (${d.drivers[0].val})</td>
          </tr>`;}).join('')}
        </tbody>
      </table>
    </div>`;
}
function runQueryDistrict(id){
  switchTab('map');
  setTimeout(()=>selectDistrict(id),100);
}

// ══ TABS ══
function switchTab(t){
  document.querySelectorAll('.ntab').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(x=>x.classList.remove('active'));
  document.getElementById('tab-'+t).classList.add('active');
  document.getElementById('panel-'+t).classList.add('active');
  if(!tabsInit[t]){tabsInit[t]=true;
    if(t==='surv')initSurv();
    if(t==='timeline')initTimeline();
    if(t==='trends')initTrends();
  }
}

