function getRiskColor(r){return r>=80?'#F87171':r>=60?'#FB923C':r>=40?'#FBBF24':'#34D399'}
function getRiskCat(r){
  if(r>=80)return{label:'Critical',color:'#F87171'};
  if(r>=60)return{label:'High Risk',color:'#FB923C'};
  if(r>=40)return{label:'Moderate',color:'#FBBF24'};
  return{label:'Low Risk',color:'#34D399'};
}
function getTypeInfo(t){return t==='mat'?{label:'Maternal',color:'#F472B6'}:{label:'Anemia',color:'#FBBF24'}}
function getRoCInfo(roc){
  if(roc>=6)return{label:`Rapidly escalating · +${roc} pts/month`,color:'#F87171',cls:'roc-up',icon:'▲▲'};
  if(roc>=3)return{label:`Escalating · +${roc} pts/month`,color:'#FB923C',cls:'roc-up',icon:'▲'};
  if(roc>0)return{label:`Slowly rising · +${roc} pts/month`,color:'#FBBF24',cls:'roc-stable',icon:'↗'};
  if(roc===0)return{label:'Stable · no change',color:'#6B8CAE',cls:'roc-stable',icon:'→'};
  return{label:`Improving · ${roc} pts/month`,color:'#34D399',cls:'roc-down',icon:'↓'};
}
function getPlainEnglish(d){
  const cat=getRiskCat(d.risk);
  const type=getTypeInfo(d.type);
  const roc=getRoCInfo(d.roc);
  if(d.risk>=80) return `${d.name} is in a <b>health emergency</b>. ${d.drivers[0].name} at ${d.drivers[0].val} is the biggest problem. Without urgent action, this will continue to get worse — risk is ${roc.label.toLowerCase()}.`;
  if(d.risk>=60) return `${d.name} has <b>high ${type.label.toLowerCase()} risk</b>. The main issue is ${d.drivers[0].name} (${d.drivers[0].val}). This needs targeted intervention soon.`;
  if(d.risk<40) return `${d.name} is a <b>benchmark district</b> — one of the healthiest in India. Its success comes from ${d.drivers[0].name} at ${d.drivers[0].val}. Other districts should replicate this model.`;
  return `${d.name} has <b>moderate ${type.label.toLowerCase()} risk</b>. Key concern is ${d.drivers[0].name} (${d.drivers[0].val}). Early intervention can prevent this from escalating.`;
}

